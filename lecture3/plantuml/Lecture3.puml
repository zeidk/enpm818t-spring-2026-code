#-------------------------
# Fig.1: Example ERD->Relational
#-------------------------
@startuml
!theme mono
hide circle
skinparam linetype ortho
skinparam defaultFontName Arial
entity PROFESSOR {
  * <color:#9b59b6><b>person_id</b></color> : int <<PK, FK -> PERSON>>
  --
  * professor_id : varchar <<UK>>
    salary : numeric
  * hire_date : date
  * <color:#336791><b>dept_id</b></color> : int <<FK -> DEPARTMENT>>
}
entity DEPARTMENT {
  * <color:#9b59b6><b>dept_id</b></color> : int <<PK>>
  --
  * dept_name : varchar <<UK>>
    building : varchar
    budget : numeric
}
DEPARTMENT ||--|{ PROFESSOR : "belongs_to"
@enduml
