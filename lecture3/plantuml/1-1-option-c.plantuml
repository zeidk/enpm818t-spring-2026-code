'-------------------------
' 1-1-option-c: FK on EMPLOYEE
'-------------------------
' LIGHT
'-------------------------
@startuml
!theme mono
hide circle
skinparam linetype ortho
skinparam defaultFontName Arial

entity EMPLOYEE {
  * <color:#9b59b6><b>emp_id</b></color> : varchar <<PK>>
  --
  * first_name : varchar
  * last_name : varchar
  * hire_date : date
  .. assigned_to (1:1) ..
    <color:#336791><b>spot_id</b></color> : varchar <<FK -> PARKING_SPOT, UK>>
}

entity PARKING_SPOT {
  * <color:#9b59b6><b>spot_id</b></color> : varchar <<PK>>
  --
  * location : varchar
}

EMPLOYEE |o--o| PARKING_SPOT : "assigned_to"
@enduml
